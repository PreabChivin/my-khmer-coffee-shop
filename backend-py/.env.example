# BENCHIMIN CAFE — AI & Analytics microservice config.
# Copy to `.env` in this directory (backend-py/.env) and fill in real values.
# This file is READ-ONLY analytics: it never writes to the DB or touches POS.

# Postgres — use the SAME database the Next.js/Prisma app uses.
# Locally: copy POSTGRES_URL_NON_POOLING from the app's .env.local
# (run `vercel env pull .env.local` in the repo root first).
# Leave empty to boot the service in "db_unavailable" mode (endpoints still
# respond, just without live data — useful for wiring/testing the bridge).
DATABASE_URL=

# Shared secret the Next.js bridge must send in the X-Internal-Api-Key header.
# MUST match PYTHON_AI_SERVICE_SECRET in the Next.js app's environment.
# Generate a long random string, e.g.:  openssl rand -hex 32
API_SECRET=change-me-in-production

# Comma-separated browser origins allowed to call this service directly
# (only relevant for local Swagger/manual testing; the real caller is the
# server-side Next.js bridge, which isn't subject to CORS).
ALLOWED_ORIGINS=http://localhost:3000

# asyncpg pool sizing (optional).
DB_POOL_MIN=1
DB_POOL_MAX=5
