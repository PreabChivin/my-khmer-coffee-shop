// Prisma schema for the Coffee Shop Website
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Product {
  id             String          @id @default(uuid())
  nameEn         String          @unique
  nameKh         String
  descriptionEn  String?
  descriptionKh  String?
  price          Float
  categoryId     String
  // ⚠️ onDelete: Cascade — deleting a Category deletes every Product in it.
  // The Category Manager's delete confirmation must surface the affected
  // product count before calling this, since there is no undo.
  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image          String
  isAvailable    Boolean         @default(true)
  // 🤝 Partner Integration: co-branded / partner-exclusive items.
  isPartner      Boolean         @default(false)
  partnerName    String?
  // 🔥 Multi-tier Discount System (foodpanda-style badges)
  //   discountPercent — % off (affects price). flatDiscount — $ off (affects
  //   price, applied after the %). promoTag — a cosmetic conditional label
  //   (e.g. "ទិញ 1 ថែម 1", "E-Power Deal") shown as a badge, no price effect.
  discountPercent Int            @default(0)
  flatDiscount   Float           @default(0)
  promoTag       String?
  // ⭐ Rating aggregate — average = ratingSum / ratingCount (guard div-by-0).
  ratingCount    Int             @default(0)
  ratingSum      Float           @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orderItems     OrderItem[]
  groupCartItems GroupCartItem[]

  @@index([categoryId])
}

// 🍩 Category Menu — data-driven homepage category slider + admin CRUD.
// name is the single display string (no separate nameEn/nameKh, unlike
// Product): admins are expected to type it in whichever language they want
// shown, consistent with this app's Khmer-default convention. iconKey is an
// optional free-text hint fed into lib/iconResolver.ts (e.g. "coffee") when
// the category name itself doesn't contain an obvious keyword; iconUrl is a
// direct override path/URL that bypasses the resolver entirely.
model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  iconKey   String?
  iconUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerPhone String
  orderType     String // 'PickUp' | 'Delivery'
  totalAmount   Float
  orderStatus   String      @default("PENDING") // 'PENDING' | 'AWAITING_VERIFICATION' | 'PREPARING' | 'READY' | 'COMPLETED' | 'CANCELLED'
  note          String?
  address       String?
  // 📍 Exact pin dropped in the delivery-address map picker (nullable — a
  // PickUp order, or a Delivery order whose address was typed manually via
  // the map picker's fallback, has no coordinates).
  latitude      Float?
  longitude     Float?
  fortune       String? // "Destiny Cup" coffee fortune assigned at checkout

  // 🎡 Wheel of Coffee prize won at checkout (label, redeemed at counter).
  spinPrize     String?

  // 🐻 Loyalty: number of free-drink rewards redeemed against this order (0 or 1).
  redeemedFreeDrinks Int     @default(0)

  // 💖 Gift a Drink ("Send Love to Crush")
  isGift            Boolean @default(false)
  giftRecipientName String?
  giftMessage       String?
  giftRedeemed      Boolean @default(false)

  // 👯 Bestie Cart: true when this order was checked out from a shared GroupCart.
  isGroupOrder Boolean @default(false)

  // ⭐ 1–5 star review the customer leaves once this order is COMPLETED.
  // Null until rated; also doubles as the "already rated" guard.
  customerRating Int?

  // 🔔 Telegram Deep Linking: set the moment the customer clicks the "🔔
  // ទទួលដំណឹងតាម Telegram" button and starts a chat with the bot via
  // /start <orderId>. Null until then — status-change notifications only
  // fire once this is present. Never the staff group id (see lib/telegram.ts).
  customerTelegramChatId String?

  // 👤 Customer account link — set when a logged-in user checks out (guests
  // leave it null). onDelete: SetNull keeps the order + its history intact if
  // the account is ever removed.
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  // 🎁 Loyalty idempotency guard — flipped true the first time this order is
  // marked COMPLETED and points are credited, so re-completing never double-awards.
  pointsAwarded Boolean     @default(false)

  // 🕒 Order Timeline — the moment each stage was first reached (set by staff
  // transitions). placedAt is createdAt; null means "not reached yet".
  preparingAt   DateTime?
  readyAt       DateTime?
  completedAt   DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  payment       Payment?

  @@index([userId])
}

// 🔐 Role-based access control. CUSTOMER is the default for every new
// sign-up; STAFF/ADMIN are granted by an existing ADMIN via the User
// Management panel (see AdminUserManagementPanel). ADMIN is the only role
// that can change roles or reset passwords for other accounts.
enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

// 👤 One unified account table for customers AND staff/admins — login,
// loyalty, and access control all key off `role`. Today: email/username +
// bcrypt password. The google/facebook/telegram id columns are scaffolded
// now so the social providers can be wired later without another migration
// (they stay null until then). The legacy `Admin` model below is retired
// (its one row was migrated in here) and kept only as an inert table until
// a later cleanup migration drops it.
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String?  @unique
  passwordHash  String? // null only for future pure-OAuth accounts
  name          String
  phone         String?
  role          Role     @default(CUSTOMER)
  // 🎂 Date of birth — used to derive the customer's generation tier
  // (lib/generation.ts). Nullable so pre-existing accounts stay valid; the
  // registration form requires it for all new sign-ups.
  dateOfBirth   DateTime?
  // 💎 Loyalty Points Reward Program (សន្សំពិន្ទុ) — lifetime points balance.
  loyaltyPoints Int      @default(0)
  // 🔮 OAuth provider scaffold (wired later once credentials exist).
  googleId      String?  @unique
  facebookId    String?  @unique
  telegramId    String?  @unique
  // 🏅 Admin-awarded personalized badges (direct gift giver).
  badges        String[] @default([])
  // 🚫 Soft-delete — set by an ADMIN via the User Management panel. Blocks
  // login (see app/api/auth/login/route.ts) without erasing any data;
  // reversible. The separate "Permanently Purge" action does a real DELETE
  // instead of touching this field.
  deactivatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
  redemptions   RedemptionHistory[]
  notifications Notification[]
  savedAddresses SavedAddress[]
  chatMessages  ChatMessage[]
  chatReactions ChatReaction[]
  chatTyping    ChatTyping?
}

// 📍 Address book — a logged-in customer's saved delivery locations, each
// with a free-text alias (e.g. "ផ្ទះ", "កន្លែងធ្វើការ", "ខុនដូ") and the
// exact pin dropped in the map picker at save time.
model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  address   String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// 🔔 Targeted Notification Engine. userId null = a broadcast shown to every
// customer; userId set = a private alert for one customer. The client bell
// treats anything newer than its last-seen marker as unread.
model Notification {
  id        String   @id @default(uuid())
  userId    String? // null = broadcast to all customers
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  href      String?
  emoji     String   @default("📣")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// 🎟️ Monthly Lucky Draw. Eligibility is a minimum lifetime-points threshold
// (tiers map to points), optionally labelled. Drawing picks a random eligible
// customer and notifies them.
model LuckyDraw {
  id          String    @id @default(uuid())
  title       String
  prizeName   String
  prizeEmoji  String    @default("🎁")
  month       String // e.g. "2026-07"
  minPoints   Int       @default(0)
  tierLabel   String?
  winnerId    String?
  winnerName  String?
  drawnAt     DateTime?
  createdAt   DateTime  @default(now())
}

// 🎁 Loyalty Redemption Store (ហាងប្ដូររង្វាន់) — catalogue of rewards a
// customer can spend points on (e.g. Free Coffee = 500 pts).
model Reward {
  id          String   @id @default(uuid())
  name        String
  nameKh      String
  cost        Int // points required
  emoji       String   @default("🎁")
  description String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  redemptions RedemptionHistory[]
}

// 🧾 One redemption event. cost + rewardName are snapshotted so the record
// stays meaningful even if the Reward is later edited/deleted. status flags
// it to staff: PENDING (needs fulfilling) -> FULFILLED (handed over).
model RedemptionHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId   String?
  reward     Reward?  @relation(fields: [rewardId], references: [id], onDelete: SetNull)
  rewardName String
  rewardEmoji String  @default("🎁")
  cost       Int
  status     String   @default("PENDING") // 'PENDING' | 'FULFILLED'
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id             String   @id @default(uuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  quantity       Int
  price          Float // unit price INCLUDING customization surcharge
  // Per-line drink customization (sweetness / ice / extra shots). Null for
  // non-customizable items such as bakery. Stored as JSONB.
  customizations Json?
  // 👯 Bestie Cart: whose drink this is, e.g. "ប្រូ វីត" — null for solo orders.
  contributorName String?
  createdAt      DateTime @default(now())
}

// 🐻 Cute Bear Stamps loyalty program, keyed by customer phone number (no
// account system exists yet, so phone is the lightweight identifier).
model LoyaltyAccount {
  id                 String   @id @default(uuid())
  phone              String   @unique
  stampCount         Int      @default(0)
  freeDrinksRedeemed Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// 🔔 Telegram device session — links a browser (via a localStorage token) to
// a Telegram chat. When a customer taps "🔔 ទទួលដំណឹងតាម Telegram" in the
// header, they connect once with no phone number; every future order placed
// from that same device is then auto-linked to this chat at checkout, so
// status updates DM them with no per-order re-linking.
model TelegramSession {
  token     String   @id
  chatId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 👯 Bestie Cart: a shared, unauthenticated cart that anyone with the link
// (?group=ID) can add items to before one person checks it out together.
model GroupCart {
  id        String          @id @default(uuid())
  status    String          @default("OPEN") // 'OPEN' | 'CHECKED_OUT'
  orderId   String?         @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     GroupCartItem[]
}

model GroupCartItem {
  id              String    @id @default(uuid())
  groupCartId     String
  groupCart       GroupCart @relation(fields: [groupCartId], references: [id], onDelete: Cascade)
  contributorName String
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  quantity        Int
  customizations  Json?
  createdAt       DateTime  @default(now())
}

model Payment {
  id            String    @id @default(uuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod String    @default("KHQR") // 'KHQR' (static shop QR, manually verified by staff)
  paymentStatus String    @default("UNPAID") // 'UNPAID' | 'PAID' | 'FAILED'
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ⚠️ RETIRED — no longer read or written by application code. Its one row
// was copied into User (role=ADMIN) by the 20260713_add_role_merge_admin
// migration. Kept in the schema/DB only so the table isn't dropped in the
// same deploy as the cutover (trivial manual rollback path); a later cleanup
// migration removes this model and DROPs the table once the new system has
// run cleanly for a few days.
model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 💬 Members' Lounge — one shared, real-time-feeling community chat room for
// every registered member (CUSTOMER/STAFF/ADMIN all post to the same stream;
// there is no per-conversation pairing, so no separate ChatRoom model is
// needed). Real-time is short-interval polling (GET ?after=<id>), matching
// every other "live" surface in this app (order board, notifications) —
// no WebSocket/Supabase/Pusher infrastructure.
model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  // 🖼️ Pasted image URL (not an uploaded file — this app has no object
  // storage service yet). Renders inline in the bubble.
  imageUrl  String?
  // 🛡️ Staff/Admin moderation soft-delete — hides the message from the feed
  // without erasing it, mirroring the User.deactivatedAt pattern.
  deletedAt DateTime?
  createdAt DateTime @default(now())
  reactions ChatReaction[]

  @@index([createdAt])
}

// ❤️🔥💀💯😭 One row per (message, user, emoji) — lets a member react with
// more than one emoji on the same message, while still toggling cleanly:
// posting the same emoji again removes it (see app/api/chat/messages/[id]/react).
model ChatReaction {
  id        String      @id @default(uuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String // one of: ❤️ 🔥 💀 💯 😭 (validated in the API route)
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
}

// ⌨️ "X is typing…" — a single row per member, upserted (debounced
// client-side) while they're actively typing. Polled alongside messages;
// a row counts as "typing" only if updatedAt is within the last few seconds,
// so stale rows just age out with no cleanup job needed.
model ChatTyping {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}
